*.bundle

# NOTE: site/content/ is generated from wiki/ by site/sync-content.mjs and is
# git-ignored via site/.gitignore. Standard Quartz globs the content/ directory
# directly (respecting config ignorePatterns, not .gitignore), so ignoring it is safe.

