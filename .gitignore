.obsidian/
tools/.venv/
__pycache__/
*.pyc
.env

# Local Claude Code config (machine-specific paths/permissions — never commit)
.claude/settings.local.json

# Wiki scratch / working files
wiki/.meta/tmp-*
wiki/.meta/fact-check-*

# History-rewrite backups
*.bundle

# NOTE: site/content/ (generated by site/scripts/stage-content.mjs) is deliberately
# NOT ignored here — Quartz's file discovery respects committed .gitignore files and
# would find 0 input files. The staging script ignores it via .git/info/exclude instead.

